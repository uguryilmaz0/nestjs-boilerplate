{
  "name": "nestjs-boilerplate",
  "version": "1.5.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "release": "commit-and-tag-version",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "dotenv -e .env.test -- prisma migrate reset --force && dotenv -e .env.test -- node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/lib-storage": "^3.1019.0",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "helmet": "^8.1.0",
    "nest-winston": "^1.10.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "slugify": "^1.6.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@prisma/studio": "^0.511.0",
    "@types/babel__core": "^7.20.5",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "commit-and-tag-version": "^12.7.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3"
  },
  "overrides": {
    "lodash": "^4.17.21",
    "tar": "^7.5.7",
    "ajv": "^8.17.2",
    "minimatch": "^10.2.1",
    "class-validator": "0.15.1",
    "@hono/node-server": "1.19.10",
    "hono": "^4.12.8",
    "fast-xml-parser": "5.5.7",
    "path-to-regexp": "^8.3.1",
    "picomatch": "^4.0.4",
    "handlebars": "^4.7.9",
    "brace-expansion": "^5.0.5",
    "yaml": "^2.8.3",
    "effect": "^3.20.0"
  }
}

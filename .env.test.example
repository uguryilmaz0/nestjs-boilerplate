# Database / Veritabanı / required for Prisma / Prisma için gerekli
# DİKKAT: Testler için Docker'da açtığımız 5433 portunu kullanıyoruz.
DATABASE_URL="postgresql://test_user:test_password@localhost:5433/test_db?schema=public"

# Node Environment / Node Ortamı (development, production, test, staging)
NODE_ENV=test

# JWT / required for authentication / kimlik doğrulama için gerekli
JWT_SECRET="test-only-secret-key-never-use-in-production"

# Storage (S3 / Supabase / MinIO)
# Testler için ayrı bir bucket (test-images) kullanılması önerilir.
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_NAME=test-images
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadminpassword

# Custom endpoint for MinIO/Supabase (leave empty for AWS)
# MinIO/Supabase için özel endpoint (AWS kullanıyorsan boş bırak)
AWS_S3_ENDPOINT=http://localhost:9000

# Server / Sunucu / required for running the application / uygulamayı çalıştırmak için gerekli
PORT=3001
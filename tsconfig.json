{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* Strict Type-Checking Options */
    "strict": true, // Tüm katı kuralları açar / All strict type-checking options are enabled
    "noImplicitAny": true, // Tipi belirtilmeyen 'any'lere izin vermez /  Disallow implicit 'any' types
    "strictNullChecks": true, // null/undefined kontrollerini zorunlu kılar /  Enable strict null checks
    "strictPropertyInitialization": false, // NestJS (DTO/Entity) için bazen false olması iyidir /  Ensure class properties are initialized in the constructor
    /* Linter-like Checks */
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false, // Geliştirme aşamasında false kalabilir
    "noUnusedParameters": false,
    "types": [
      "node",
      "jest",
      "babel__core"
    ],
  }
}